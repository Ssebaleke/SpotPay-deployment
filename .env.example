# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Allowed Hosts & CSRF
ALLOWED_HOSTS=your-vps-ip,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://your-vps-ip:8001,http://127.0.0.1:8000

# Optional: Site Configuration
SITE_URL=http://your-vps-ip:8001
PORTAL_API_BASE=http://your-vps-ip:8001/api/portal

# Optional: CORS (if needed)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_ALL_ORIGINS=False
