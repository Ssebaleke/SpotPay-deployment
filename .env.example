# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Allowed Hosts & CSRF
ALLOWED_HOSTS=spotpay.it.com,www.spotpay.it.com,your-vps-ip,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://spotpay.it.com,https://www.spotpay.it.com,http://your-vps-ip:8001,http://127.0.0.1:8000

# Site Configuration
SITE_URL=https://spotpay.it.com
PORTAL_API_BASE=https://spotpay.it.com/api/portal

# Yo! Payments credentials (stored in PaymentProvider DB record — these are fallback env vars)
YO_API_USERNAME=your-yo-api-username
YO_API_PASSWORD=your-yo-api-password
# Optional: override default Yo! endpoints
# YO_API_PRIMARY_URL=https://paymentsapi1.yo.co.ug/ybs/task.php
# YO_API_BACKUP_URL=https://paymentsapi2.yo.co.ug/ybs/task.php

# Optional: CORS — do NOT set CORS_ALLOWED_ORIGINS, captive portal requires all origins allowed
# CORS_ALLOW_ALL_ORIGINS is hardcoded True in settings.py
