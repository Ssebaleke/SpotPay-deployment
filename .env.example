# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Allowed Hosts & CSRF
ALLOWED_HOSTS=spotpay.it.com,www.spotpay.it.com,your-vps-ip,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://spotpay.it.com,https://www.spotpay.it.com,http://your-vps-ip:8001,http://127.0.0.1:8000

# Site Configuration
SITE_URL=https://spotpay.it.com
PORTAL_API_BASE=https://spotpay.it.com/api/portal

# Yo! Payments credentials (stored in PaymentProvider DB record — these are fallback env vars)
YO_API_USERNAME=your-yo-api-username
YO_API_PASSWORD=your-yo-api-password
# Optional: override default Yo! endpoints
# YO_API_PRIMARY_URL=https://paymentsapi1.yo.co.ug/ybs/task.php
# YO_API_BACKUP_URL=https://paymentsapi2.yo.co.ug/ybs/task.php

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SpotPay <your-email@gmail.com>

# Mikhmon
MIKHMON_URL=http://YOUR_VPS_IP:8081
MIKHMON_USER=admin
MIKHMON_PASS=your_mikhmon_password

# VPS SSH (required for WireGuard peer registration and Mikhmon config injection)
VPS_SSH_HOST=YOUR_VPS_PUBLIC_IP
VPS_SSH_USER=root
VPS_SSH_PASS=your_vps_root_password

# WireGuard VPN (injected into MikroTik setup script)
VPN_SERVER_IP=YOUR_VPS_PUBLIC_IP
VPN_SERVER_PORT=51820
VPN_SERVER_PUBLIC_KEY=YOUR_WIREGUARD_SERVER_PUBLIC_KEY
VPN_INTERFACE_NAME=wg0
VPN_SUBNET=10.10.0
# Each location gets an IP like 10.10.0.X — assigned automatically

# Optional: CORS — do NOT set CORS_ALLOWED_ORIGINS, captive portal requires all origins allowed
# CORS_ALLOW_ALL_ORIGINS is hardcoded True in settings.py
